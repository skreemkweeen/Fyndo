{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/creator/[handle]",
      "regex": "^/creator/([^/]+?)(?:/)?$",
      "routeKeys": { "nxtPhandle": "nxtPhandle" },
      "namedRegex": "^/creator/(?<nxtPhandle>[^/]+?)(?:/)?$"
    },
    {
      "page": "/live/[id]",
      "regex": "^/live/([^/]+?)(?:/)?$",
      "routeKeys": { "nxtPid": "nxtPid" },
      "namedRegex": "^/live/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product/[id]",
      "regex": "^/product/([^/]+?)(?:/)?$",
      "routeKeys": { "nxtPid": "nxtPid" },
      "namedRegex": "^/product/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/feed",
      "regex": "^/feed(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/feed(?:/)?$"
    },
    {
      "page": "/messages",
      "regex": "^/messages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/messages(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc"
  },
  "rewrites": []
}
